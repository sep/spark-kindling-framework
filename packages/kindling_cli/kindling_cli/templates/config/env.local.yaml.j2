# Local development overlay.
#
# By default, entities use the in-memory provider — no Azure credentials needed.
# To switch to real ABFSS storage, comment out provider_type and uncomment
# provider.path for each entity below after setting the required env vars.
#
# Note: @secret:VAR_NAME resolves from environment variables on the standalone
# platform — no KeyVault needed for local development.

kindling:
  delta:
    access_mode: storage

# --- Local-only entity configuration (no cloud credentials needed) ---
#
# Using provider_type: memory keeps all entity data in Spark memory tables.
# Perfect for running and testing pipelines without Azure access.
entity_tags:
{% if layers == "medallion" %}
  bronze.records:
    provider_type: "memory"
    # To use ABFSS instead, comment out provider_type and uncomment provider.path:
    # provider.path: "@secret:ABFSS_BRONZE_PATH"
  silver.records:
    provider_type: "memory"
    # To use ABFSS instead, comment out provider_type and uncomment provider.path:
    # provider.path: "@secret:ABFSS_SILVER_PATH"
{% else %}
  raw.records:
    provider_type: "memory"
    # To use ABFSS instead, comment out provider_type and uncomment provider.path:
    # provider.path: "@secret:ABFSS_RAW_PATH"
{% endif %}

# --- ABFSS credentials ---
# Requires env vars set in .env:
{% if auth == "oauth" %}
#   AZURE_STORAGE_ACCOUNT, AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET
{% elif auth == "key" %}
#   AZURE_STORAGE_ACCOUNT, AZURE_STORAGE_KEY
{% else %}
#   AZURE_STORAGE_ACCOUNT  (run `az login` first)
{% endif %}
