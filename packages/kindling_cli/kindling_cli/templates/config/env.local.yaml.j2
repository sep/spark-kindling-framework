# Local development overlay — ABFSS paths resolved from environment variables.
#
# Credential env vars ({{ auth }} auth):
{% if auth == "oauth" -%}
#   AZURE_STORAGE_ACCOUNT   storage account name
#   AZURE_TENANT_ID          AAD tenant ID
#   AZURE_CLIENT_ID          service principal app ID
#   AZURE_CLIENT_SECRET      service principal secret
{%- elif auth == "key" %}
#   AZURE_STORAGE_ACCOUNT   storage account name
#   AZURE_STORAGE_KEY        storage account key
{%- else %}
#   AZURE_STORAGE_ACCOUNT   storage account name
#   (run `az login` before running tests)
{%- endif %}
#
# Path env vars:
{% if layers == "medallion" -%}
#   ABFSS_BRONZE_PATH=abfss://<container>@<account>.dfs.core.windows.net/<path>
#   ABFSS_SILVER_PATH=abfss://<container>@<account>.dfs.core.windows.net/<path>
{%- else %}
#   ABFSS_RAW_PATH=abfss://<container>@<account>.dfs.core.windows.net/<path>
{%- endif %}

{% if layers == "medallion" %}
entity_tags:
  bronze.records:
    provider.path: "@secret:ABFSS_BRONZE_PATH"
  silver.records:
    provider.path: "@secret:ABFSS_SILVER_PATH"
{% else %}
entity_tags:
  raw.records:
    provider.path: "@secret:ABFSS_RAW_PATH"
{% endif %}
