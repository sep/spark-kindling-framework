def pytest_configure(config):
    config.addinivalue_line("markers", "unit: local Spark tests, no Azure or ABFSS")
    config.addinivalue_line("markers", "component: DI wiring tests, no ABFSS")
    config.addinivalue_line("markers", "integration: requires live Spark and ABFSS")
    config.addinivalue_line("markers", "requires_azure: skipped when Azure creds are absent")
