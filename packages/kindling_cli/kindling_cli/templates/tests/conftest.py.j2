AZURE_CLOUD_CONFIGS = {
    "AzurePublicCloud": {
        "aliases": {"AzurePublicCloud", "AZURE_PUBLIC_CLOUD", "public", "publiccloud"},
        "authority": "https://login.microsoftonline.com",
        "storage_suffix": "core.windows.net",
        "storage_scope": "https://storage.azure.com/.default",
    },
    "AzureUSGovernment": {
        "aliases": {"AzureUSGovernment", "AZURE_US_GOVERNMENT", "government", "gov", "usgov"},
        "authority": "https://login.microsoftonline.us",
        "storage_suffix": "core.usgovcloudapi.net",
        "storage_scope": "https://storage.usgovcloudapi.net/.default",
    },
    "AzureChinaCloud": {
        "aliases": {"AzureChinaCloud", "AZURE_CHINA_CLOUD", "china"},
        "authority": "https://login.chinacloudapi.cn",
        "storage_suffix": "core.chinacloudapi.cn",
        "storage_scope": "https://storage.chinacloudapi.cn/.default",
    },
}


def _azure_env(name: str, default: str) -> str:
    return os.getenv(name, default).strip().rstrip("/")


def _azure_cloud_config() -> dict:
    value = os.getenv("AZURE_CLOUD") or "AzurePublicCloud"
    folded = value.replace("-", "").replace("_", "").lower()
    for name, config in AZURE_CLOUD_CONFIGS.items():
        aliases = {name, *config["aliases"]}
        if any(alias.replace("-", "").replace("_", "").lower() == folded for alias in aliases):
            return config
    return AZURE_CLOUD_CONFIGS["AzurePublicCloud"]


def _storage_dfs_endpoint(account: str) -> str:
    suffix = _azure_env(
        "AZURE_STORAGE_DFS_ENDPOINT_SUFFIX",
        f"dfs.{_azure_cloud_config()['storage_suffix']}",
    ).lstrip(".")
    return f"{account}.{suffix}"


def _storage_token_scope() -> str:
    return _azure_env("AZURE_STORAGE_TOKEN_SCOPE", _azure_cloud_config()["storage_scope"])


def _login_endpoint(tenant: str) -> str:
    authority = _azure_env("AZURE_AUTHORITY_HOST", _azure_cloud_config()["authority"])
    return f"{authority}/{tenant}/oauth2/token"

def pytest_collection_modifyitems(config, items):
    for item in items:
        if "requires_azure" in item.keywords and not _azure_creds_available():
            item.add_marker(pytest.mark.skip(reason="Azure credentials not set"))
