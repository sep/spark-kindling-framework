"""Local integration tests — exercises Kindling pipe wiring with in-memory providers.

No Azure credentials required. Run these alongside unit and component tests.
"""

import pytest

pytestmark = pytest.mark.integration


class TestKindlingPipeExecution:
    """Exercise the generated Kindling pipe wiring with a local SparkSession.

    Uses memory providers so no ABFSS credentials are needed.
    """

    @pytest.fixture(autouse=True)
    def _setup(self, spark_local, reset_kindling):
        from kindling.bootstrap import initialize_framework

        self.spark = spark_local
        self.svc = initialize_framework(
            {
                "platform": "standalone",
                "environment": "local",
                "config_files": ["settings.yaml", "settings.local.yaml"],
            }
        )
        import {{ snake_name }}.entities.records  # noqa: F401
{% if layers == "medallion" %}
        import {{ snake_name }}.pipes.bronze_to_silver  # noqa: F401
{% else %}
        import {{ snake_name }}.pipes.process  # noqa: F401
{% endif %}

    def test_generated_pipe_runs_through_kindling(self):
        from kindling.data_pipes import DataPipesExecution
        from kindling.injection import get_kindling_service

        executor = get_kindling_service(DataPipesExecution)
{% if layers == "medallion" %}
        executor.run_datapipes(["bronze_to_silver"])
{% else %}
        executor.run_datapipes(["process_records"])
{% endif %}
