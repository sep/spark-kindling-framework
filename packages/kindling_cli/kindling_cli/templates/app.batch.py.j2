import os
import sys
from pathlib import Path

# Local dev: make the checked-out package importable without installing it.
# In deployed environments the wheel is loaded from artifacts storage.
_src = Path(__file__).resolve().parents[2] / "packages" / "{{ package_snake_name }}" / "src"
if _src.exists() and str(_src) not in sys.path:
    sys.path.insert(0, str(_src))

import {{ package_snake_name }}.entities.records  # noqa: F401
{% if layers == "medallion" %}import {{ package_snake_name }}.pipes.bronze_to_silver  # noqa: F401
{% else %}import {{ package_snake_name }}.pipes.process  # noqa: F401
{% endif %}
from kindling.bootstrap import initialize_framework
from kindling.data_pipes import DataPipesExecution, DataPipesRegistry
from kindling.injection import get_kindling_service

_env = os.environ.get("KINDLING_ENV", "local")
_config_dir = Path(os.environ.get("KINDLING_CONFIG_DIR", "")) or Path(__file__).resolve().parent / "config"
_configs = [str(_config_dir / "settings.yaml")]
_env_file = _config_dir / f"env.{_env}.yaml"
if _env_file.exists():
    _configs.append(str(_env_file))

initialize_framework({"platform": "standalone", "environment": _env, "config_files": _configs})

registry = get_kindling_service(DataPipesRegistry)
execution = get_kindling_service(DataPipesExecution)
execution.run_datapipes(sorted(registry.get_pipe_ids()), use_dag=True)
