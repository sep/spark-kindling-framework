name: CI

on:
  push:
    branches: ["main", "master"]
  pull_request:
  workflow_dispatch:

env:
  REGISTRY: ghcr.io

jobs:
  test:
    runs-on: ubuntu-latest
    # Use the versioned devcontainer image — has Java 21, Poetry, and kindling
    # wheels pre-installed so `poetry install` resolves without hitting PyPI.
    container:
      image: ghcr.io/sep/spark-kindling-framework/devcontainer:{{ kindling_version }}
      credentials:
        username: ${{ "{{" }} github.actor {{ "}}" }}
        password: ${{ "{{" }} secrets.GITHUB_TOKEN {{ "}}" }}

    steps:
      - name: Check out code
        uses: actions/checkout@v4

      - name: Test all packages
        shell: bash
        run: |
          set -euo pipefail
          found=0
          for pkg in packages/*; do
            if [ -f "$pkg/pyproject.toml" ]; then
              found=1
              echo "==> Testing $pkg"
              (cd "$pkg" && poetry install --no-interaction && poetry run poe test && poetry run poe build)
            fi
          done
          if [ "$found" -eq 0 ]; then
            echo "No scaffolded packages found under packages/."
            exit 1
          fi
