services:
  devcontainer:
    build:
      context: .
      dockerfile: Dockerfile
    volumes:
      - ..:/workspaces/{{ repo_snake_name }}:cached
      - spark-warehouse:/spark-warehouse
    command: sleep infinity
    environment:
{% if primary_package_snake_name %}
      - PYTHONPATH=/workspaces/{{ repo_snake_name }}/packages/{{ primary_package_snake_name }}/src
{% endif %}
      - SPARK_LOCAL_IP=127.0.0.1

volumes:
  spark-warehouse:
