# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.
#
# Load with: export $(grep -v '^#' .env | xargs)
# Or use a tool like direnv or python-dotenv.

# --- Credentials ({{ auth }} auth) ---
{% if auth == "oauth" -%}
AZURE_STORAGE_ACCOUNT=<storage-account-name>
AZURE_TENANT_ID=<aad-tenant-id>
AZURE_CLIENT_ID=<service-principal-app-id>
AZURE_CLIENT_SECRET=<service-principal-secret>
{%- elif auth == "key" %}
AZURE_STORAGE_ACCOUNT=<storage-account-name>
AZURE_STORAGE_KEY=<storage-account-key>
{%- else %}
AZURE_STORAGE_ACCOUNT=<storage-account-name>
# Run `az login` before executing integration tests — no secret needed here.
{%- endif %}

# --- Azure cloud endpoints ---
# Kindling derives endpoints from AZURE_CLOUD. Override individual values
# only when you need to force a custom endpoint.
# Azure Government example:
# AZURE_CLOUD=AzureUSGovernment
# AZURE_STORAGE_DFS_ENDPOINT_SUFFIX=dfs.core.usgovcloudapi.net
# AZURE_STORAGE_BLOB_ENDPOINT_SUFFIX=blob.core.usgovcloudapi.net
# AZURE_STORAGE_TOKEN_SCOPE=https://storage.usgovcloudapi.net/.default
# AZURE_AUTHORITY_HOST=https://login.microsoftonline.us

# --- ABFSS entity paths ---
{% if layers == "medallion" -%}
ABFSS_BRONZE_PATH=abfss://<container>@<account>.<dfs-endpoint-suffix>/bronze/records
ABFSS_SILVER_PATH=abfss://<container>@<account>.<dfs-endpoint-suffix>/silver/records
{%- else %}
ABFSS_RAW_PATH=abfss://<container>@<account>.<dfs-endpoint-suffix>/raw/records
{%- endif %}

# --- Optional ---
# KINDLING_ENV=local
