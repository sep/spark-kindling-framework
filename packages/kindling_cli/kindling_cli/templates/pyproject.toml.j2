# Kindling packages are resolved from the devcontainer image's local PEP 503
# index so `poetry install` works without a PyPI connection.
# Outside the devcontainer (e.g. CI using the same image), this source is
# present at the same path and resolution is identical.
[[tool.poetry.source]]
name = "kindling-packages"
url = "file:///opt/kindling-packages/simple/"
priority = "supplemental"

[build-system]
requires = ["poetry-core>=1.0.0"]
build-backend = "poetry.core.masonry.api"

[tool.poetry]
name = "{{ kebab_name }}"
version = "0.1.0"
description = "Kindling data pipeline project — {{ kebab_name }}"
packages = [{include = "{{ snake_name }}", from = "src"}]

[tool.poetry.dependencies]
python = "^3.10"
# The runtime distribution is published as `spark-kindling`, while imports
# remain `import kindling`. The standalone extra pulls in local Spark deps.
spark-kindling = {version = ">={{ kindling_version }}", extras = ["standalone"]}

[tool.poetry.group.dev.dependencies]
pytest = ">=7.0.0"
pytest-cov = ">=4.0.0"
poethepoet = ">=0.24.0"
spark-kindling-cli = ">={{ kindling_version }}"

[tool.poe.tasks]
test-unit = "pytest tests/unit -v"
test-component = "pytest tests/component -v"
{% if integration %}
test-integration = "pytest tests/integration -v"
test-all = { sequence = ["test-unit", "test-component", "test-integration"] }
{% endif %}
test = { sequence = ["test-unit", "test-component"] }
build = "poetry build"

[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = ["test_*.py"]
python_classes = ["Test*"]
python_functions = ["test_*"]
markers = [
    "unit: local Spark unit tests, no ABFSS",
    "component: DI wiring, no ABFSS",
{% if integration %}
    "integration: requires Spark and ABFSS credentials",
    "requires_azure: skipped when Azure credentials are not set",
{% endif %}
]
