"""{{ kebab_name }} — Kindling file-ingestion app entrypoint.

Run locally:    kindling app run .
Run remotely:   kindling app run . --platform <platform>

Set KINDLING_INGESTION_PATH to the source path to ingest.
"""

import os
from pathlib import Path

# Import your domain package(s) here so their entities are registered.
# Example:
#   import {{ package_snake_name }}.entities.records  # noqa: F401
from kindling.bootstrap import initialize_framework
from kindling.file_ingestion import FileIngestionProcessor
from kindling.injection import get_kindling_service

_env = os.environ.get("KINDLING_ENV", "local")
_config_dir_env = os.environ.get("KINDLING_CONFIG_DIR")
_config_dir = Path(_config_dir_env) if _config_dir_env else Path(__file__).resolve().parent / "config"
_configs = [str(_config_dir / "settings.yaml")]
_env_file = _config_dir / f"env.{_env}.yaml"
if _env_file.exists():
    _configs.append(str(_env_file))

initialize_framework({"platform": "standalone", "environment": _env, "config_files": _configs})

source_path = os.environ.get("KINDLING_INGESTION_PATH")
if not source_path:
    raise RuntimeError("Set KINDLING_INGESTION_PATH to the source path to ingest.")

processor = get_kindling_service(FileIngestionProcessor)
processor.process_path(source_path)
